# Copy this file to .env.local and fill in your personal values.
# .env.local is gitignored — never commit it.

# ---------------------------------------------------------------------------
# Shared Problem Statements folder (OneDrive-synced SharePoint).
# Used by problem-framing-coach to write a copy to the shared team folder.
# Leave empty to save locally only.
# ---------------------------------------------------------------------------
PROBLEM_STATEMENTS_SHARED_PATH=

# ---------------------------------------------------------------------------
# Confluence credentials — OPTIONAL / CI-CD alternative.
# For local developer workstations, prefer ~/.confluence-cli/config.json
# (written by scripts/setup-confluence.sh) — the token never enters the repo.
# Only set these if you need to override the config file (e.g. in CI/CD,
# Docker, or environments where writing to ~ is not possible).
# ---------------------------------------------------------------------------
# CONFLUENCE_DOMAIN=confluence.zurich.com
# CONFLUENCE_API_PATH=/rest/api
# CONFLUENCE_AUTH_TYPE=bearer
# CONFLUENCE_API_TOKEN=<your-personal-access-token>
